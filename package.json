{
  "name": "niconi-compare",
  "displayName": "Niconi compare",
  "version": "0.0.1",
  "description": "ニコニコ動画の視聴中に動画を比較し続け、あなたの嗜好を自動的にレーティング・ランキング化するブラウザ拡張機能。",
  "author": "horyu <28817604+horyu@users.noreply.github.com>",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "package": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "fix": "pnpm format && pnpm lint",
    "check": "run-p types:check lint:check format:check",
    "types:check": "tsc --noEmit",
    "lint": "oxlint --fix && eslint --fix \"./**/*.{ts,tsx}\"",
    "lint:check": "oxlint --deny-warnings && eslint --max-warnings 0 \"./**/*.{ts,tsx}\"",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "glicko2-lite": "5.0.0",
    "immer": "11.1.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@storybook/addon-themes": "10.3.5",
    "@storybook/react-vite": "10.3.5",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.1.40",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@wxt-dev/module-react": "1.2.2",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-oxlint": "1.61.0",
    "eslint-plugin-storybook": "10.3.5",
    "happy-dom": "20.9.0",
    "npm-run-all2": "8.0.4",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "storybook": "10.3.5",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wxt": "0.20.25"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
